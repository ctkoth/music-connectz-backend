    DJANGO_SECRET_KEY, DEBUG (False), ALLOWED_HOSTS, FRONTEND_URL,
    STRIPE_SECRET_KEY, STRIPE_WEBHOOK_SECRET,
    STRIPE_PRICE_PREMIUM_MONTHLY, STRIPE_PRICE_PREMIUM_ANNUAL,
    STRIPE_PRICE_STATZ_MONTHLY, STRIPE_PRICE_STATZ_ANNUAL,
    ANTHROPIC_API_KEY, OPENAI_API_KEY,
    GOOGLE_OAUTH_CLIENT_ID/SECRET, SPOTIFY_OAUTH_CLIENT_ID/SECRET,
