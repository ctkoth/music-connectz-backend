# In dev when EMAIL_HOST is unset, fall back to console backend (prints emails to stdout)
if not EMAIL_HOST and not DEBUG:
    pass  # production with no email = silent fail (verification still works via dev console log)
elif not EMAIL_HOST:
    EMAIL_BACKEND = 'django.core.mail.backends.console.EmailBackend'
