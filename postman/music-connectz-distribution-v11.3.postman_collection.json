{
  "info": {
    "name": "Music ConnectZ Distribution v11.3",
    "description": "Requests for distribution submission fields and Ditto webhook testing.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Distribution - Submission Fields",
      "item": [
        {
          "name": "Get Submission Fields",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Cookie",
                "value": "{{auth_cookie}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/distribution/releases/{{release_id}}/submission-fields/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "distribution",
                "releases",
                "{{release_id}}",
                "submission-fields",
                ""
              ]
            },
            "description": "Fetch editable submission fields for the release."
          }
        },
        {
          "name": "Patch Submission Fields",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Cookie",
                "value": "{{auth_cookie}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"New Release Title\",\n  \"genre\": \"Bossa Nova\",\n  \"language\": \"pt-br\",\n  \"explicit\": false\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/distribution/releases/{{release_id}}/submission-fields/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "distribution",
                "releases",
                "{{release_id}}",
                "submission-fields",
                ""
              ]
            },
            "description": "Update editable submission metadata."
          }
        },
        {
          "name": "Get Release Status",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Cookie",
                "value": "{{auth_cookie}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/distribution/releases/{{release_id}}/status/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "distribution",
                "releases",
                "{{release_id}}",
                "status",
                ""
              ]
            },
            "description": "Check normalized release status after webhook updates."
          }
        }
      ]
    },
    {
      "name": "Distribution - Ditto Webhooks",
      "item": [
        {
          "name": "Send Signed Ditto Webhook",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const payload = {",
                  "  event_type: pm.variables.get('event_type') || 'release.updated',",
                  "  status: pm.variables.get('provider_status') || 'processing',",
                  "  provider_release_id: pm.variables.get('provider_release_id'),",
                  "  local_release_id: Number(pm.variables.get('release_id') || 0),",
                  "  event_time: new Date().toISOString(),",
                  "  data: {",
                  "    provider_release_id: pm.variables.get('provider_release_id'),",
                  "    status: pm.variables.get('provider_status') || 'processing',",
                  "    source: 'postman'",
                  "  }",
                  "};",
                  "pm.variables.set('webhook_payload', JSON.stringify(payload));",
                  "",
                  "const secret = pm.variables.get('ditto_webhook_secret') || '';",
                  "if (secret) {",
                  "  const signature = CryptoJS.HmacSHA256(pm.variables.get('webhook_payload'), secret).toString(CryptoJS.enc.Hex);",
                  "  pm.variables.set('ditto_signature', signature);",
                  "} else {",
                  "  pm.variables.set('ditto_signature', '');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Ditto-Signature",
                "value": "{{ditto_signature}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{{webhook_payload}}"
            },
            "url": {
              "raw": "{{base_url}}/api/distribution/webhooks/ditto/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "distribution",
                "webhooks",
                "ditto",
                ""
              ]
            },
            "description": "Posts a signed Ditto webhook payload."
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:8000"
    },
    {
      "key": "release_id",
      "value": "1"
    },
    {
      "key": "provider_release_id",
      "value": "local-1-1712234567"
    },
    {
      "key": "event_type",
      "value": "release.updated"
    },
    {
      "key": "provider_status",
      "value": "processing"
    },
    {
      "key": "ditto_webhook_secret",
      "value": "replace_with_ditto_secret"
    },
    {
      "key": "ditto_signature",
      "value": ""
    },
    {
      "key": "webhook_payload",
      "value": "{}"
    }
  ]
}
